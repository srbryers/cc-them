{
  "name": "cc-them",
  "version": "0.4.1",
  "description": "Sourced reasoning agents for Claude Code — expert pushback on code, architecture, and strategy, grounded in public works",
  "type": "module",
  "bin": {
    "cc-them": "./dist/scripts/cli.js"
  },
  "scripts": {
    "build": "tsc -p scripts/tsconfig.json && tsc -p mcp/tsconfig.json",
    "prepublishOnly": "npm run build",
    "validate": "node scripts/validate.js",
    "validate:all": "node scripts/validate.js",
    "dev:mcp": "tsx mcp/src/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@slope-dev/slope": "^1.33.0",
    "@types/node": "^22.0.0",
    "puppeteer": "^24.39.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "code-review",
    "mcp",
    "ai-agents",
    "reasoning",
    "architecture"
  ],
  "files": [
    "dist/",
    "scripts/validate.js",
    "profiles/",
    "schema/",
    "mcp/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/srbryers/cc-them"
  },
  "license": "MIT"
}
